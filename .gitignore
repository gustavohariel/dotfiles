.DS_Store
*.log
*.swp
.netrwhist

# Niri rolls .bak.<timestamp> when its UI rewrites configs — runtime state, not tracked.
*.bak.*

# fish runtime state and host-local secrets.
fish_variables
private.fish

# OMP plugin installs are regenerated from the tracked manifests.
omp/.omp/plugins/node_modules/
omp/.omp/plugins/cache/

# Noctalia hubstaff plugin lives in its own repo (~/sandbox/noctalia-hubstaff)
# and is symlinked into ~/.config/noctalia/plugins/ at runtime — don't capture here.
noctalia/.config/noctalia/plugins/hubstaff/
