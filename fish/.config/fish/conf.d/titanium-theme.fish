# Titanium fish theme — matched to Herdr titanium UI.
# Fish color values are hex without the leading '#'.
set -g fish_color_normal d7dde7
set -g fish_color_command 00b4ff
set -g fish_color_keyword 00b4ff
set -g fish_color_quote 00ff88
set -g fish_color_redirection 00d7d7
set -g fish_color_end 9aa6b8
set -g fish_color_error ff4757 --bold
set -g fish_color_param c6ced8
set -g fish_color_valid_path c6ced8 --underline
set -g fish_color_option ffb347
set -g fish_color_comment 7f8a9b --italics
set -g fish_color_selection d7dde7 --background=27303a
set -g fish_color_operator 00d7d7
set -g fish_color_escape 00d7d7
set -g fish_color_autosuggestion 7f8a9b
set -g fish_color_cwd 00b4ff
set -g fish_color_cwd_root ff4757
set -g fish_color_user 00ff88
set -g fish_color_host 9aa6b8
set -g fish_color_host_remote 00d7d7
set -g fish_color_status ff4757
set -g fish_color_cancel ff4757 --reverse
set -g fish_color_search_match d7dde7 --background=27303a
set -g fish_color_history_current 00b4ff --bold

set -g fish_pager_color_progress 00b4ff --bold
set -g fish_pager_color_background
set -g fish_pager_color_prefix 00b4ff --bold
set -g fish_pager_color_completion d7dde7
set -g fish_pager_color_description 7f8a9b
set -g fish_pager_color_selected_background --background=27303a
set -g fish_pager_color_selected_prefix 00b4ff --bold
set -g fish_pager_color_selected_completion d7dde7
set -g fish_pager_color_selected_description c6ced8
set -g fish_pager_color_secondary_background --background=1f252d
set -g fish_pager_color_secondary_prefix 00b4ff
set -g fish_pager_color_secondary_completion c6ced8
set -g fish_pager_color_secondary_description 7f8a9b
