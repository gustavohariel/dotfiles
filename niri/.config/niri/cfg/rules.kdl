    window-rule {
        geometry-corner-radius 20 // Set every window radius to 20
        clip-to-geometry true
    }

    window-rule {
        background-effect {
            xray true
            blur true
        }
    }

     // if you use steam you will probably like these
    window-rule {
        match app-id="steam"
        exclude title=r#"^[Ss]team$"#
        open-floating true
    }

    window-rule {
       match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
       default-floating-position x=10 y=10 relative-to="bottom-right"
       open-focused false
    }

    window-rule {
        match app-id="scrcpy"
        default-column-width { fixed 561; }
    }

    window-rule {
        match app-id="GStreamer" title="Linux iPhone Mirror"
        default-column-width { fixed 632; }
    }

    window-rule {
        match app-id="^t3code$"
        default-column-width { proportion 0.5; }
        draw-border-with-background false
    }

    window-rule {
        match app-id="^zen$"
        draw-border-with-background false
    }

    window-rule {
        match app-id=r#"^org\.gnome\.Nautilus$"#
        draw-border-with-background false
    }

    window-rule {
        match app-id=r#"^dev\.zed\.Zed(-Preview)?$"#
        draw-border-with-background false
    }

    // Android Studio emulator: the phone (title `Android Emulator …`) and
    // the extended-controls sidebar (title `Emulator`) are two separate
    // top-level windows sharing `app-id=Emulator`. Cap each to its
    // natural width so tiling doesn't leave a black canvas next to the
    // skin and the sidebar doesn't claim a half-screen column.
    window-rule {
        match app-id="^Emulator$" title=r#"^Android Emulator"#
        default-column-width { fixed 647; }
    }

    // The sidebar's buttons are broken on this Wayland session — hide it
    // entirely instead of letting it eat a column. Park it far off-screen
    // (niri clamps to a sliver, hidden via opacity 0 + chrome off) so the
    // emulator process keeps its second top-level alive without showing.
    window-rule {
        match app-id="^Emulator$" title="^Emulator$"
        open-floating true
        open-focused false
        default-floating-position x=65000 y=65000 relative-to="top-left"
        opacity 0.0
        border { off; }
        focus-ring { off; }
        shadow { off; }
        background-effect {
            xray false
            blur false
        }
        clip-to-geometry false
        geometry-corner-radius 0
    }

    layer-rule {
        match namespace="^noctalia-wallpaper*"
        place-within-backdrop true
    }
