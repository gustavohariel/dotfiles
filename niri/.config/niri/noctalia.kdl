layout {

    focus-ring {
        active-color   "#00b4ff"  // titanium primary
        inactive-color "#1f252d"  // titanium surface variant
        urgent-color   "#ff4757"  // titanium error
    }

    border {
        active-color   "#00b4ff"
        inactive-color "#1f252d"
        urgent-color   "#ff4757"
    }

    shadow {
        color "#05070a80"  // titanium shadow at 50%
    }

    tab-indicator {
        active-color   "#00b4ff"
        inactive-color "#0082b3"  // titanium cyan (darker primary)
        urgent-color   "#ff4757"
    }

    insert-hint {
        color "#00b4ff80"  // titanium primary at 50%
    }
}

recent-windows {
    highlight {
        active-color "#00b4ff"
        urgent-color "#ff4757"
    }
}
