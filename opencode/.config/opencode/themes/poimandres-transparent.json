{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#1b1e28",
    "gray": "#a6accd",
    "offWhite": "#e4f0fb",
    "darkerGray": "#767c9d",
    "bluishGray": "#506477",
    "bluishGrayBrighter": "#7390AA",
    "desaturatedBlue": "#91B4D5",
    "lightBlue": "#ADD7FF",
    "lowerBlue": "#89ddff",
    "brightMint": "#5DE4c7",
    "lowerMint": "#5fb3a1",
    "hotRed": "#d0679d",
    "pink": "#f087bd",
    "brightYellow": "#fffac2",
    "focus": "#303340",
    "white": "#ffffff"
  },
  "theme": {
    "primary": { "dark": "lightBlue", "light": "lightBlue" },
    "secondary": { "dark": "desaturatedBlue", "light": "desaturatedBlue" },
    "accent": { "dark": "brightMint", "light": "brightMint" },
    "error": { "dark": "hotRed", "light": "hotRed" },
    "warning": { "dark": "brightYellow", "light": "brightYellow" },
    "success": { "dark": "lowerMint", "light": "lowerMint" },
    "info": { "dark": "lightBlue", "light": "lightBlue" },
    "text": { "dark": "gray", "light": "gray" },
    "textMuted": { "dark": "darkerGray", "light": "darkerGray" },
    "background": { "dark": "none", "light": "none" },
    "backgroundPanel": { "dark": "none", "light": "none" },
    "backgroundElement": { "dark": "none", "light": "none" },
    "border": { "dark": "none", "light": "none" },
    "borderActive": { "dark": "none", "light": "none" },
    "borderSubtle": { "dark": "none", "light": "none" },
    "diffAdded": { "dark": "lowerMint", "light": "lowerMint" },
    "diffRemoved": { "dark": "hotRed", "light": "hotRed" },
    "diffContext": { "dark": "darkerGray", "light": "darkerGray" },
    "diffHunkHeader": { "dark": "darkerGray", "light": "darkerGray" },
    "diffHighlightAdded": { "dark": "brightMint", "light": "brightMint" },
    "diffHighlightRemoved": { "dark": "hotRed", "light": "hotRed" },
    "markdownText": { "dark": "gray", "light": "gray" },
    "markdownHeading": { "dark": "offWhite", "light": "offWhite" },
    "markdownLink": { "dark": "lightBlue", "light": "lightBlue" },
    "markdownLinkText": { "dark": "brightMint", "light": "brightMint" },
    "markdownCode": { "dark": "brightMint", "light": "brightMint" },
    "markdownBlockQuote": { "dark": "bluishGrayBrighter", "light": "bluishGrayBrighter" },
    "markdownEmph": { "dark": "bluishGrayBrighter", "light": "bluishGrayBrighter" },
    "markdownStrong": { "dark": "bluishGrayBrighter", "light": "bluishGrayBrighter" },
    "markdownHorizontalRule": { "dark": "darkerGray", "light": "darkerGray" },
    "markdownListItem": { "dark": "lightBlue", "light": "lightBlue" },
    "markdownListEnumeration": { "dark": "lowerMint", "light": "lowerMint" },
    "markdownImage": { "dark": "lowerBlue", "light": "lowerBlue" },
    "markdownImageText": { "dark": "offWhite", "light": "offWhite" },
    "markdownCodeBlock": { "dark": "offWhite", "light": "offWhite" },
    "syntaxComment": { "dark": "darkerGray", "light": "darkerGray" },
    "syntaxKeyword": { "dark": "gray", "light": "gray" },
    "syntaxFunction": { "dark": "lightBlue", "light": "lightBlue" },
    "syntaxVariable": { "dark": "offWhite", "light": "offWhite" },
    "syntaxString": { "dark": "brightMint", "light": "brightMint" },
    "syntaxNumber": { "dark": "brightMint", "light": "brightMint" },
    "syntaxType": { "dark": "gray", "light": "gray" },
    "syntaxOperator": { "dark": "desaturatedBlue", "light": "desaturatedBlue" },
    "syntaxPunctuation": { "dark": "gray", "light": "gray" },
    "diffAddedBg": { "dark": "none", "light": "none" },
    "diffRemovedBg": { "dark": "none", "light": "none" },
    "diffContextBg": { "dark": "none", "light": "none" },
    "diffAddedLineNumberBg": { "dark": "none", "light": "none" },
    "diffRemovedLineNumberBg": { "dark": "none", "light": "none" }
  }
}
